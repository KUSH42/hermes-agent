/*
 * hermes_cli/tui/hermes.tcss
 *
 * VISUAL properties (colours, margins, padding) only.
 * Structural properties (height, overflow, display, dock) belong in
 * each widget's DEFAULT_CSS — see CSS precedence rule in spec §4.13.
 *
 * Precedence: DEFAULT_CSS < CSS class var < external .tcss < inline styles.
 * Keep structural properties in DEFAULT_CSS and visual properties here
 * to avoid precedence surprises.
 */

HermesApp {
    background: $background;
}

* {
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
}

/* --- Message turns --- */

MessagePanel {
    margin: 1 0 0 0;
}

/* --- Reasoning panel --- */

ReasoningPanel {
    margin: 0 1;
}

/* --- Input rule separator --- */

#input-rule {
    color: $primary-darken-3;
}

/* --- Hint bar --- */

HintBar {
    color: $text-muted;
}

/* --- Status bar --- */

StatusBar {
    background: $background;
    color: $text-muted;
    padding: 0 1;
}

/* --- Overlay widgets --- */

ClarifyWidget,
ApprovalWidget,
SudoWidget,
SecretWidget {
    margin: 0 1;
}

/* Overlay layer — stacks overlays vertically, hidden unless children are visible */
#overlay-layer {
    height: auto;
}

/* --- Input area --- */

#input-row {
    height: 1;
    padding: 0 1;
}

#input-chevron {
    color: #FFF8DC;
    width: 2;
    height: 1;
}

#spinner-overlay {
    display: none;
    height: 1;
    width: 1fr;
    color: $text-muted;
}

HermesInput {
    background: transparent;
    border: none;
    padding: 0;
    height: 1;
    width: 1fr;
}

HermesInput > .input--cursor {
    color: #FFF8DC;
    background: #FFF8DC;
}

HermesInput > .input--selection {
    background: #3A5A8C;
}

HermesInput > .input--placeholder {
    color: #555555;
    text-style: italic;
}

/* --- Image bar --- */

ImageBar {
    color: $text-muted;
    padding: 0 1;
}

/* --- Voice status bar --- */

VoiceStatusBar {
    padding: 0 1;
}
