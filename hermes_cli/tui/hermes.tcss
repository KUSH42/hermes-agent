/*
 * hermes_cli/tui/hermes.tcss
 *
 * VISUAL properties (colours, margins, padding) only.
 * Structural properties (height, overflow, display, dock) belong in
 * each widget's DEFAULT_CSS — see CSS precedence rule in spec §4.13.
 *
 * Precedence: DEFAULT_CSS < CSS class var < external .tcss < inline styles.
 * Keep structural properties in DEFAULT_CSS and visual properties here
 * to avoid precedence surprises.
 *
 * Component Part variables — ThemeManager overrides at runtime via
 * App.get_css_variables().  Defaults here are authoritative for first render.
 * Override in your skin file's component_vars section:
 *
 *   component_vars:
 *     cursor-color:        "#FFD700"
 *     cursor-selection-bg: "#1E4080"
 *     cursor-placeholder:  "#666666"
 */
$cursor-color: #FFF8DC;
$cursor-selection-bg: #3A5A8C;
$cursor-placeholder: #555555;

/* Chevron phase colours — ThemeManager overrides via component_vars */
$chevron-base: #FFF8DC;
$chevron-file: #FFBF00;
$chevron-stream: #6EA8D4;
$chevron-shell: #A8D46E;
$chevron-done: #4CAF50;
$chevron-error: #E06C75;

/* Fuzzy match highlight — ThemeManager overrides via component_vars */
$fuzzy-match-color: #FFD866;

/* Status / pulse indicators — ThemeManager overrides via component_vars */
$status-running-color: #FFBF00;
$status-error-color: #ef5350;
$status-context-color: #5f87d7;

/* TitledRule colours — ThemeManager overrides via component_vars */
$rule-dim-color: #555555;
$rule-bg-color: #2A2A2A;
$rule-accent-color: #FFD700;
$rule-accent-dim-color: #B8860B;

HermesApp {
    background: $background;
}

* {
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
}

/* --- Message turns --- */

MessagePanel {
    margin: 1 0 0 0;
    transition: opacity 0.3s in_out_cubic;
}

MessagePanel.--entering {
    opacity: 0.0;
}

/* --- Reasoning panel --- */

ReasoningPanel {
    margin: 0 1;
}

/* --- Input rule separator --- */

#input-rule {
    color: $primary-darken-3;
}

/* --- Hint bar ---
 * Always 1 line tall (no display:none toggling) to prevent layout reflow
 * jitter when hints appear/disappear during streaming.  Empty hint renders
 * as a blank line — visually invisible, zero layout cost to show/hide.
 */
HintBar {
    color: $text-muted;
}

/* --- Status bar --- */

StatusBar {
    background: $background;
    color: $text-muted;
    padding: 0 1;
}

/* --- Overlay widgets --- */

ClarifyWidget,
ApprovalWidget,
SudoWidget,
SecretWidget {
    margin: 0 1;
}

/* Overlay layer — stacks overlays vertically, hidden unless children are visible */
#overlay-layer {
    height: auto;
}

/* --- Input area --- */

#input-row {
    height: 1;
    padding: 0 1;
    background: $background;
}

#input-chevron {
    color: $chevron-base;
    width: 2;
    height: 1;
    transition: color 0.2s in_out_cubic;
}

/* Chevron phase colours — set by _set_chevron_phase() */
#input-chevron.--phase-file   { color: $chevron-file; }
#input-chevron.--phase-stream { color: $chevron-stream; }
#input-chevron.--phase-shell  { color: $chevron-shell; }
#input-chevron.--phase-done   { color: $chevron-done; }
#input-chevron.--phase-error  { color: $chevron-error; }

#spinner-overlay {
    display: none;
    height: 1;
    width: 1fr;
    color: $text-muted;
}

HermesInput {
    background: $background;
    border: none;
    padding: 0;
    height: 1;
    width: 1fr;
}

/* Prevent Textual's Input:focus tint from creating a contrast stripe */
HermesInput:focus {
    background: $background;
}

/* Component Part variables — themed via ThemeManager.component_vars.
 * Defaults are defined in theme_manager.COMPONENT_VAR_DEFAULTS and
 * injected through HermesApp.get_css_variables().  Override by adding
 * a component_vars section to your skin JSON/YAML:
 *
 *   component_vars:
 *     cursor-color:        "#FFD700"
 *     cursor-selection-bg: "#1E4080"
 *     cursor-placeholder:  "#666666"
 */
HermesInput > .input--cursor {
    color: $cursor-color;
    background: $cursor-color;
}

HermesInput > .input--selection {
    background: $cursor-selection-bg;
}

HermesInput > .input--placeholder {
    color: $cursor-placeholder;
    text-style: italic;
}

/* Ghost text styling — scoped to HermesInput only so other Input widgets
 * (history search, sudo/secret overlays) are not inadvertently affected. */
HermesInput > .input--suggestion {
    color: $text-muted 60%;
    text-style: italic;
}

/* --- Image bar --- */

ImageBar {
    color: $text-muted;
    padding: 0 1;
}

/* --- Voice status bar --- */

VoiceStatusBar {
    padding: 0 1;
}

/* --- Glassmorphism: completion menu --- */

VirtualCompletionList {
    background: $panel 40%;
    border: tall $primary 20%;
    border-top: hkey $accent 50%;
    tint: $primary 8%;
    color: $text;
}

VirtualCompletionList:focus {
    border: tall $accent 50%;
    tint: $accent 12%;
}

/* Selected row background — paired with Strip.apply_style in render_line */
VirtualCompletionList > .completion--row-selected {
    background: $accent 25%;
    text-style: bold;
}

/* Preview panel divider */
PreviewPanel {
    border-left: vkey $primary 30%;
    background: $panel 30%;
    padding: 0 1;
}

/* --- Clipboard warning indicator --- */

#status-clipboard-warning {
    color: $warning;
    background: transparent;
    display: none;
}

#status-clipboard-warning.--active {
    display: block;
}

/* --- ToolBlock widgets --- */

/* ToolHeader: structural height:1 is in DEFAULT_CSS */
ToolHeader {
    margin-left: 0;
    transition: background 0.4s in_out_cubic;
}

/* ToolHeader — hover affordance */
ToolHeader:hover {
    background: $accent 8%;
}

/* ToolHeader — brief green flash on streaming completion (#2) */
ToolHeader.--flash-complete {
    background: $success 18%;
}

/* ToolBodyContainer body lines — indent matches the ┊ gutter.
 * max-height increased from 40 → 60 to reduce scroll fatigue on long outputs. */
ToolBodyContainer CopyableRichLog {
    padding-left: 0;
    height: auto;
    max-height: 60;
    overflow-y: auto;
    overflow-x: hidden;
}

/* --- Context menu ---
 * Hover uses $accent at low opacity — $primary can be near-black in dark
 * themes, making $primary 30% nearly invisible against $panel background. */
ContextMenu > _ContextItem:hover { background: $accent 15%; }
ContextMenu > _ContextSep { color: $text-muted; }

/* --- History search overlay (SPEC-B) --- */

#history-search-input {
    border: none;
    background: $surface;
    padding: 0 1;
    margin-bottom: 1;
}

#history-result-list {
    height: auto;
    max-height: 14;
    overflow-y: auto;
    overflow-x: hidden;
}

#history-status {
    color: $text-muted;
    text-align: right;
    padding: 0 1;
}

TurnResultItem {
    height: 1;
    padding: 0 1;
}

/* Use $cursor-selection-bg for consistent selection style with VirtualCompletionList
 * and HermesInput text selection — all three represent "selected item". */
TurnResultItem.--selected {
    background: $cursor-selection-bg;
}

TurnResultItem:hover {
    background: $accent 10%;
}

/* History jump highlight — 0.5s is fast enough for expert users who chain
 * multiple jumps; was 1.5s which caused visible lag between jumps. */
MessagePanel.--highlighted {
    background: $accent 15%;
    transition: background 0.5s in_out_cubic;
}

/* --- Overlay focus rings (§2.6) --- */

ClarifyWidget:focus,
ApprovalWidget:focus {
    outline: tall $accent 50%;
}

/* --- Reduced motion (HERMES_REDUCED_MOTION=1) --- */

HermesApp.reduced-motion MessagePanel           { transition: none; }
HermesApp.reduced-motion MessagePanel.--highlighted { transition: none; }
HermesApp.reduced-motion #input-chevron         { transition: none; }
HermesApp.reduced-motion ToolHeader             { transition: none; }

/* --- Density: compact mode (§2.9) --- */

HermesApp.density-compact MessagePanel          { margin: 0; }
HermesApp.density-compact ReasoningPanel        { margin: 0; }
HermesApp.density-compact UserEchoPanel         { margin: 0; padding: 0 1; }
HermesApp.density-compact StatusBar             { padding: 0; }
HermesApp.density-compact HintBar               { padding: 0; }
HermesApp.density-compact ImageBar              { padding: 0; }
HermesApp.density-compact VoiceStatusBar        { padding: 0; }
HermesApp.density-compact #input-row            { padding: 0; }
HermesApp.density-compact ToolBodyContainer CopyableRichLog { max-height: 25; }
/* Overlays: trim extra padding to match standard 0 1 in compact mode */
HermesApp.density-compact ClarifyWidget,
HermesApp.density-compact ApprovalWidget,
HermesApp.density-compact SudoWidget,
HermesApp.density-compact SecretWidget          { padding: 0 1; }
HermesApp.density-compact UndoConfirmOverlay    { padding: 0 1; }
