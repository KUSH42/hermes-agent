/*
 * hermes_cli/tui/hermes.tcss
 *
 * VISUAL properties (colours, margins, padding) only.
 * Structural properties (height, overflow, display, dock) belong in
 * each widget's DEFAULT_CSS — see CSS precedence rule in spec §4.13.
 *
 * Precedence: DEFAULT_CSS < CSS class var < external .tcss < inline styles.
 * Keep structural properties in DEFAULT_CSS and visual properties here
 * to avoid precedence surprises.
 *
 * Component Part variables — ThemeManager overrides at runtime via
 * App.get_css_variables().  Defaults here are authoritative for first render.
 * Override in your skin file's component_vars section:
 *
 *   component_vars:
 *     cursor-color:        "#FFD700"
 *     cursor-selection-bg: "#1E4080"
 *     cursor-placeholder:  "#666666"
 */
/* All $var defaults live in COMPONENT_VAR_DEFAULTS (theme_manager.py).
   Local declarations here block runtime skin overrides. */

/* Screen is the actual DOM root — transparent widgets inherit from it, not from
 * HermesApp. Both must be set so every widget in the tree shows $app-bg. */
Screen {
    background: $app-bg;
}

HermesApp {
    background: $app-bg;
}

* {
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
    scrollbar-background: $app-bg;
    scrollbar-background-hover: $app-bg;
    scrollbar-background-active: $app-bg;
    scrollbar-corner-color: $app-bg;
}

/* OutputPanel: show scrollbar so terminal scrollbar controls pane scrolling.
   $scrollbar is Textual's built-in var — skins override it in component_vars
   to match the scrollbar to their palette. */
OutputPanel {
    scrollbar-size-vertical: 1;
    scrollbar-color: $scrollbar 60%;
}

/* --- Message turns --- */

MessagePanel {
    margin: 1 0 0 0;
    transition: opacity 0.3s in_out_cubic;
}

/* RichLog.DEFAULT_CSS sets background: $surface.  Override both response-text
 * and reasoning log to $app-bg so all content areas share the same background
 * as the chrome widgets above (HermesApp, StatusBar, #input-row, HermesInput).
 * Users can shift the whole-app tone by setting app-bg in component_vars. */
CopyableRichLog {
    background: $app-bg;
}

StreamingCodeBlock {
    background: $app-bg;
}

CodeBlockFooter {
    color: $text-muted;
    background: $app-bg;
}

CodeBlockFooter:hover {
    color: $accent;
    background: $accent 8%;
}


MessagePanel.--entering {
    opacity: 0.0;
}

/* --- Reasoning panel ---
 * border-left: vkey draws the vertical gutter character on EVERY visual row
 * (including line-wrap continuations), fixing the alignment bug that text-
 * prepended ▌ had — it only appeared on the first row of wrapped lines. */

ReasoningPanel {
    margin: 0 2;
    border-left: vkey $primary 40%;
}

/* Hover affordance on closeable reasoning panels */
ReasoningPanel.--closeable:hover {
    background: $accent 5%;
}

/* Reasoning panel code blocks — dimmed to match reasoning prose */
ReasoningPanel StreamingCodeBlock {
    opacity: 0.7;
    border: round $surface-darken-2;
    margin: 0 0 1 2;
}

ReasoningPanel StreamingCodeBlock .code-block-footer {
    color: $text-muted;
}

/* --- Input rule separator ---
 * TitledRule manages all its own colors via _live_colors() + inline Rich styles.
 * No CSS color override needed here — it would conflict with the inline styles. */

/* --- Hint bar ---
 * Always 1 line tall (no display:none toggling) to prevent layout reflow
 * jitter when hints appear/disappear during streaming.  Empty hint renders
 * as a blank line — visually invisible, zero layout cost to show/hide.
 */
HintBar {
    color: $text-muted;
    padding: 0 1;
}

/* --- Status bar --- */

StatusBar {
    background: $app-bg;
    color: $text-muted;
    padding: 0 1;
}

/* --- Overlay widgets --- */

ClarifyWidget,
ApprovalWidget,
SudoWidget,
SecretWidget,
UndoConfirmOverlay {
    margin: 0 1;
    padding: 1 2;
}

/* Overlay layer — stacks overlays vertically, hidden unless children are visible */
#overlay-layer {
    height: auto;
}

/* --- Input area --- */

#input-row {
    height: auto;
    padding: 0 1;
    background: $app-bg;
}

#input-chevron {
    color: $chevron-base;
    width: 2;
    height: auto;
    min-height: 1;
    content-align: left top;
    transition: color 0.2s in_out_cubic;
}

/* Chevron phase colours — set by _set_chevron_phase() */
#input-chevron.--phase-file   { color: $chevron-file; }
#input-chevron.--phase-stream { color: $chevron-stream; }
#input-chevron.--phase-shell  { color: $chevron-shell; }
#input-chevron.--phase-done   { color: $chevron-done; }
#input-chevron.--phase-error  { color: $chevron-error; }

#spinner-overlay {
    display: none;
    height: 1;
    width: 1fr;
    color: $text-muted;
}

HermesInput {
    background: $app-bg;
    border: none;
    padding: 0;
    height: auto;
    max-height: 3;
    width: 1fr;
    scrollbar-size: 1 1;
}

/* Prevent Textual's TextArea:focus tint from creating a contrast stripe */
HermesInput:focus {
    background: $app-bg;
}

/* Component Part variables — themed via ThemeManager.component_vars.
 * Defaults are defined in theme_manager.COMPONENT_VAR_DEFAULTS and
 * injected through HermesApp.get_css_variables().  Override by adding
 * a component_vars section to your skin JSON/YAML:
 *
 *   component_vars:
 *     cursor-color:        "#FFD700"
 *     cursor-selection-bg: "#1E4080"
 *     cursor-placeholder:  "#666666"
 */
HermesInput > .text-area--cursor {
    color: $cursor-color;
    background: $cursor-color;
}

HermesInput > .text-area--selection {
    background: $cursor-selection-bg;
}

HermesInput > .text-area--placeholder {
    color: $cursor-placeholder;
    text-style: italic;
}

/* Ghost text styling — scoped to HermesInput only.
 * $ghost-text-color (#555555) gives ~2.5:1 contrast — dim but readable. */
HermesInput > .text-area--suggestion {
    color: $ghost-text-color;
    text-style: italic;
}

/* --- Image bar --- */

ImageBar {
    color: $text-muted;
    padding: 0 1;
}

/* --- TTE startup effect widget ---
 * Structural CSS (layer, dock, display) is in TTEWidget.DEFAULT_CSS.
 * Only visual overrides here. */

TTEWidget {
    background: $app-bg;
}

/* --- Voice status bar --- */

VoiceStatusBar {
    padding: 0 1;
}

/* --- Completion overlay: elevated panel design ---
 *
 * Depth is achieved through brightness hierarchy, not alpha:
 *   $app-bg  #1E1E1E  output pane (deepest)
 *   $panel   #252526  preview panel (mid)
 *   $surface #2D2D30  list panel (closest, brightest)
 *
 * The accent top stripe spans the full overlay width and acts as the
 * primary elevation signal — like a light catch on a raised surface.
 * No opacity hacks; Textual composites against parent bg, not content. */

CompletionOverlay {
    border-top: hkey $accent 60%;
}

VirtualCompletionList {
    background: $surface-lighten-1;
    color: $text;
}

/* Selected row — accent fill + bold; no border needed */
VirtualCompletionList > .completion--row-selected {
    background: $accent 18%;
    text-style: bold;
}

/* Preview panel — one step darker than list, reads as "behind" */
PreviewPanel {
    border-left: vkey $primary 40%;
    background: $surface;
    padding: 0 1;
}

/* --- Clipboard warning indicator --- */

#status-clipboard-warning {
    color: $warning;
    background: transparent;
    display: none;
}

#status-clipboard-warning.--active {
    display: block;
}

/* --- ToolBlock widgets --- */

/* ToolHeader: structural height:1 is in DEFAULT_CSS */
ToolHeader {
    margin-left: 0;
    transition: background 0.4s in_out_cubic;
}

/* ToolHeader — hover affordance */
ToolHeader:hover {
    background: $accent 8%;
}

/* ToolHeader — brief green flash on streaming completion (#2) */
ToolHeader.--flash-complete {
    background: $success 18%;
}
ToolHeader.--flash-success {
    background: $success 35%;
    transition: background 400ms out_cubic;
}
ToolHeader.--flash-error {
    background: $error 35%;
    transition: background 400ms out_cubic;
}

/* ToolBodyContainer body lines — no individual scroll.
 * Content flows into OutputPanel (the single scroll container).
 * overflow: hidden prevents nested scroll from creating stale offsets
 * that corrupt dirty-rect renders when the mouse moves after scrolling. */
ToolBodyContainer CopyableRichLog {
    padding-left: 0;
    height: auto;
    overflow-y: hidden;
    overflow-x: hidden;
}

/* --- Context menu ---
 * Hover uses $accent at low opacity — $primary can be near-black in dark
 * themes, making $primary 30% nearly invisible against $panel background. */
ContextMenu { background: $panel; }
ContextMenu > _ContextItem:hover { background: $accent 15%; }
ContextMenu > _ContextSep { color: $text-muted; }

/* --- History search overlay (SPEC-B) --- */

#history-search-input {
    border: none;
    background: $surface;
    padding: 0 1;
    margin-bottom: 1;
}

#history-result-list {
    height: auto;
    max-height: 1fr;
    overflow-y: auto;
    overflow-x: hidden;
}

#history-status {
    color: $text-muted;
    text-align: right;
    padding: 0 1;
}

TurnResultItem {
    height: auto;
    min-height: 2;
    max-height: 4;
    padding: 0 1;
    margin-bottom: 1;
}

/* Use $cursor-selection-bg for consistent selection style with VirtualCompletionList
 * and HermesInput text selection — all three represent "selected item". */
TurnResultItem.--selected {
    background: $cursor-selection-bg;
}

TurnResultItem:hover {
    background: $accent 10%;
}

/* History jump highlight — 0.5s is fast enough for expert users who chain
 * multiple jumps; was 1.5s which caused visible lag between jumps. */
MessagePanel.--highlighted {
    background: $accent 15%;
    transition: background 0.5s in_out_cubic;
}

/* --- Overlay focus rings (§2.6) --- */

ClarifyWidget:focus,
ApprovalWidget:focus {
    outline: tall $accent 50%;
}

/* --- Reduced motion (HERMES_REDUCED_MOTION=1) --- */

HermesApp.reduced-motion MessagePanel           { transition: none; }
HermesApp.reduced-motion MessagePanel.--highlighted { transition: none; }
HermesApp.reduced-motion #input-chevron         { transition: none; }
HermesApp.reduced-motion ToolHeader             { transition: none; }

/* P0-A: Disable transitions on all overlay widgets under reduced-motion.
 * Countdown color lerp continues (color change, not positional motion). */
HermesApp.reduced-motion ClarifyWidget,
HermesApp.reduced-motion ApprovalWidget,
HermesApp.reduced-motion SudoWidget,
HermesApp.reduced-motion SecretWidget,
HermesApp.reduced-motion UndoConfirmOverlay,
HermesApp.reduced-motion KeymapOverlay,
HermesApp.reduced-motion HistorySearchOverlay   { transition: none; }

/* --- FPS HUD overlay --- */

FPSCounter {
    background: $fps-hud-bg;
    color: $accent;
    padding: 0 1;
}

/* --- Density: compact mode (§2.9) --- */

HermesApp.density-compact MessagePanel          { margin: 0; }
HermesApp.density-compact ReasoningPanel        { margin: 0; }
HermesApp.density-compact CopyableBlock         { margin: 0; }
HermesApp.density-compact UserMessagePanel         { margin: 0; padding: 0 1; }
HermesApp.density-compact StatusBar             { padding: 0; }
HermesApp.density-compact HintBar               { padding: 0; }
HermesApp.density-compact ImageBar              { padding: 0; }
HermesApp.density-compact VoiceStatusBar        { padding: 0; }
HermesApp.density-compact #input-row            { padding: 0; }
/* Overlays: trim extra padding to match standard 0 1 in compact mode */
HermesApp.density-compact ClarifyWidget,
HermesApp.density-compact ApprovalWidget,
HermesApp.density-compact SudoWidget,
HermesApp.density-compact SecretWidget          { padding: 0 1; }
HermesApp.density-compact UndoConfirmOverlay    { padding: 0 1; }

/* ── Drawille Overlay ──────────────────────────────────────── */
/* layer: overlay lives here (not DEFAULT_CSS) to avoid CSS parse issues
   when drawille_overlay.py is imported before HermesApp CSS loads. */

DrawilleOverlay {
    layer: overlay;
    position: absolute;
    background: $surface 0%;
}

DrawilleOverlay.-show-border {
    border: round $accent;
}

/* Declaration required at parse time so ThemeManager injection works. */
DrawilleOverlay > .drawille-overlay--canvas {
    color: $drawille-canvas-color;
}

AnimConfigPanel {
    layer: overlay;
    align: right top;
    margin: 1 1 0 0;
    border: round $surface-darken-2;
    background: $surface;
    color: $text;
}

/* ── OmissionBar — expand/collapse controls for line cap ─────────────── */

OmissionBar .omission-label {
    width: 1fr;
    color: $text-muted;
}

OmissionBar .omission-btn {
    width: auto;
    padding: 0 1;
    color: $primary;
}

OmissionBar .omission-btn:hover {
    background: $primary 20%;
}

OmissionBar .omission-btn.-disabled {
    color: $text-disabled;
}

/* --- Tool Panel v2 (tui-tool-panel-v2-spec.md §10) ---
 * Accent bar rules apply when a panel carries tool-panel--accent class
 * (set when display.tool_panel_v2: true in config). */

/* --- Tool Panel v2 (tui-tool-panel-v2-spec.md §10) ---
 * Accent bar rules apply when a panel carries tool-panel--accent class
 * (set when display.tool_panel_v2: true in config).
 * Only Textual built-in design tokens used here — component vars ($text-muted
 * etc.) are not resolved at TCSS parse time for border-left. */

ToolPanel.tool-panel--accent                 { border-left: vkey $accent 30%; }
ToolPanel.category-file.tool-panel--accent   { border-left: vkey $accent 80%; }
ToolPanel.category-shell.tool-panel--accent  { border-left: vkey $warning 80%; }
ToolPanel.category-code.tool-panel--accent   { border-left: vkey $primary 80%; }
ToolPanel.category-search.tool-panel--accent { border-left: vkey $primary 60%; }
ToolPanel.category-web.tool-panel--accent    { border-left: vkey $success 80%; }
ToolPanel.category-agent.tool-panel--accent  { border-left: vkey $accent 20%; }
ToolPanel.tool-panel--error                  { border-left: vkey $error 80%; }
ToolPanel:focus                              { background: $accent 10%; }

/* --- Tool grouping (virtual — no DOM container) --- */
ToolPanel.tool-panel--grouped { padding-left: 2; }
ToolPanel.group-hidden         { display: none; }

GroupHeader {
    height: 1;
    color: $text-muted;
    background: $surface;
    padding: 0 1;
}
GroupHeader:focus { background: $accent 10%; }
